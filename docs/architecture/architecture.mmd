%% ============================================================
%% DIAGRAM 2: Registration + Email Verification Flow (AC-001)
%% Rev 2: Uses SignUp + ConfirmSignUp (native Cognito OTP)
%% Rev 3: Email delivery via CustomEmailSender Lambda + KMS + SES
%% ============================================================

sequenceDiagram
    participant User
    participant Frontend
    participant MembersLambda
    participant SeedDB as DynamoDB (SeedMembersTable)
    participant MembersDB as DynamoDB (MembersTable)
    participant Cognito
    participant CES as CustomEmailSender Lambda
    participant KMS as AWS KMS
    participant SES as Amazon SES

    Note over User,Cognito: ── STEP 1: Registration (POST /v1/auth/register) ──

    User->>Frontend: Fill DNI, email, password on /register
    Frontend->>MembersLambda: POST /v1/auth/register { dni, email, password }
    MembersLambda->>SeedDB: GetItem { pk: "DNI#<dni>" }
    alt DNI not found
        MembersLambda-->>Frontend: 404 DNI_NOT_FOUND
    end
    alt account_status == inactive
        MembersLambda-->>Frontend: 403 ACCOUNT_INACTIVE
    end
    MembersLambda->>MembersDB: Query GSI_DNI + GSI_Email (duplicate check)
    alt Already registered
        MembersLambda-->>Frontend: 409 DNI_ALREADY_REGISTERED / EMAIL_ALREADY_IN_USE
    end
    MembersLambda->>Cognito: SignUp { email, password, custom:dni } — user UNCONFIRMED
    Cognito->>CES: Trigger CustomEmailSender { code (KMS-encrypted), email }
    CES->>KMS: Decrypt code (AWS Encryption SDK envelope format)
    KMS-->>CES: Plaintext 6-digit OTP
    CES->>SES: SendEmail { to: email, body: OTP code }
    SES->>User: Email with 6-digit OTP code (TTL 24h)
    MembersLambda-->>Frontend: HTTP 202 — Code sent to email

    Note over User,Cognito: ── STEP 2: Email Verification (POST /v1/auth/verify-email) ──

    User->>Frontend: Enter 6-digit OTP code on /verify-email
    Frontend->>MembersLambda: POST /v1/auth/verify-email { email, code }
    MembersLambda->>Cognito: ConfirmSignUp { email, code }
    alt Code invalid / expired
        MembersLambda-->>Frontend: 400 INVALID_CODE / 410 CODE_EXPIRED
    end
    Cognito-->>MembersLambda: User status → CONFIRMED
    MembersLambda->>Cognito: AdminGetUser → read custom:dni + sub
    MembersLambda->>SeedDB: GetItem → get membership_type
    MembersLambda->>Cognito: AdminAddUserToGroup { GroupName: "Member" }
    MembersLambda->>MembersDB: PutItem { MEMBER#<ulid>, PROFILE, all fields }
    MembersLambda-->>Frontend: HTTP 201 — Account activated
    Frontend->>Frontend: Redirect to /login

%% ============================================================
%% DIAGRAM 3: Stripe Payment + Webhook Flow
%% ============================================================

sequenceDiagram
    participant Member
    participant Frontend
    participant PaymentsLambda
    participant DynamoDB as DynamoDB (PaymentsTable + MembersTable)
    participant Stripe

    Member->>Frontend: Click "Pay Membership"
    Frontend->>PaymentsLambda: POST /v1/payments/checkout { billingCycle }
    PaymentsLambda->>Stripe: Create Checkout Session
    Stripe-->>PaymentsLambda: { sessionId, sessionUrl }
    PaymentsLambda->>DynamoDB: PutItem payment (status=Pending)
    PaymentsLambda-->>Frontend: { sessionUrl }
    Frontend->>Stripe: Redirect to Stripe Checkout
    Member->>Stripe: Complete payment
    Stripe->>PaymentsLambda: POST /v1/payments/webhook (checkout.session.completed)
    PaymentsLambda->>PaymentsLambda: Verify Stripe signature
    PaymentsLambda->>DynamoDB: UpdateItem payment (status=Succeeded)
    PaymentsLambda->>DynamoDB: UpdateItem member (status=Active, membershipExpiry=...)
    Frontend->>Frontend: Redirect to success page

%% ============================================================
%% DIAGRAM 4: Promotions Broadcast Flow (SNS)
%% ============================================================

sequenceDiagram
    participant Manager
    participant Frontend
    participant PromotionsLambda
    participant DynamoDB as DynamoDB (PromotionsTable)
    participant SNS
    participant Members

    Manager->>Frontend: Create promotion + click Broadcast
    Frontend->>PromotionsLambda: POST /v1/promotions/:id/broadcast
    PromotionsLambda->>DynamoDB: GetItem promotion
    PromotionsLambda->>SNS: Publish(topicArn, message, attributes: { membershipTier })
    SNS-->>Members: Email / Push notification delivered to filtered subscribers
    PromotionsLambda->>DynamoDB: UpdateItem promotion (broadcastAt = now)
    PromotionsLambda-->>Frontend: 200 { broadcastAt }

%% ============================================================
%% DIAGRAM 5: Login + OTP MFA Flow (AC-002)
%% Uses AdminInitiateAuth + AdminRespondToAuthChallenge (EMAIL_OTP)
%% Rev 3: Email delivery via CustomEmailSender Lambda + KMS + SES
%% ============================================================

sequenceDiagram
    participant User
    participant Frontend
    participant MembersLambda
    participant Cognito
    participant CES as CustomEmailSender Lambda
    participant KMS as AWS KMS
    participant SES as Amazon SES

    Note over User,Cognito: ── STEP 1: Credential Validation (POST /v1/auth/login) ──

    User->>Frontend: Enter email + password on /login
    Frontend->>MembersLambda: POST /v1/auth/login { email, password }
    MembersLambda->>Cognito: AdminInitiateAuth { USER_PASSWORD_AUTH, email, password }
    alt Invalid credentials
        Cognito-->>MembersLambda: NotAuthorizedException / UserNotFoundException
        MembersLambda-->>Frontend: 401 INVALID_CREDENTIALS (generic — no user enumeration)
    end
    alt Account UNCONFIRMED
        Cognito-->>MembersLambda: UserNotConfirmedException
        MembersLambda-->>Frontend: 403 ACCOUNT_NOT_CONFIRMED
    end
    Cognito->>CES: Trigger CustomEmailSender { code (KMS-encrypted), email }
    CES->>KMS: Decrypt code (AWS Encryption SDK envelope format)
    KMS-->>CES: Plaintext 6-digit OTP
    CES->>SES: SendEmail { to: email, body: OTP code }
    SES->>User: EMAIL_OTP code (TTL 3 min)
    Cognito-->>MembersLambda: { ChallengeName: EMAIL_OTP, Session: <token> }
    MembersLambda-->>Frontend: HTTP 200 { challengeName, session }

    Note over User,Cognito: ── STEP 2: OTP Verification (POST /v1/auth/verify-otp) ──

    User->>Frontend: Enter 6-digit OTP code
    Frontend->>MembersLambda: POST /v1/auth/verify-otp { email, session, otp }
    MembersLambda->>Cognito: AdminRespondToAuthChallenge { EMAIL_OTP, session, otp }
    alt Code invalid
        Cognito-->>MembersLambda: CodeMismatchException
        MembersLambda-->>Frontend: 400 INVALID_OTP
    end
    alt Session expired (> 3 min)
        Cognito-->>MembersLambda: ExpiredCodeException
        MembersLambda-->>Frontend: 410 SESSION_EXPIRED
    end
    Cognito-->>MembersLambda: { AuthenticationResult: { AccessToken, IdToken, RefreshToken } }
    MembersLambda-->>Frontend: HTTP 200 { accessToken, idToken, refreshToken, expiresIn }
    Frontend->>Frontend: Store tokens in memory / httpOnly cookie
    Frontend->>Frontend: Redirect to /dashboard
