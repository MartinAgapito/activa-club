    end

    subgraph API["Amazon API Gateway HTTP API"]
        APIGW["HTTP API /v1/*"]
        Authorizer["JWT Authorizer (Cognito)"]
        APIGW --> Authorizer
    end

    subgraph Lambdas["AWS Lambda (one per service)"]
        LM["activa-club-members"]
        LR["activa-club-reservations"]
        LP["activa-club-payments"]
        LPR["activa-club-promotions"]
        LG["activa-club-guests"]
        LA["activa-club-areas"]
        LAD["activa-club-admin"]
    end

    subgraph DynamoDB["Amazon DynamoDB (Multi-Table)"]
        MT["MembersTable"]
        RT["ReservationsTable"]
        PT["PaymentsTable"]
        PRT["PromotionsTable"]
        GT["GuestsTable"]
        AT["AreasTable"]
    end

    subgraph Email["Email Pipeline"]
        CES["CustomEmailSender Lambda"]
        KMS["AWS KMS (decryption)"]
        SES["Amazon SES"]
        CES --> KMS
        CES --> SES
    end

    subgraph External["External Services"]
        Stripe["Stripe (Payments)"]
        SNS["Amazon SNS (Notifications)"]
    end

