# Enforce LF line endings for all text files
* text=auto eol=lf

# Explicit LF for source files
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.tf   text eol=lf
*.hcl  text eol=lf
*.sh   text eol=lf
*.env  text eol=lf
*.css  text eol=lf
*.html text eol=lf

# Binary files — no conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.zip  binary
*.gz   binary
