{
  "name": "reservations-expirer",
  "version": "1.0.0",
  "description": "AC-016 — Automatic reservation expiration Lambda",
  "scripts": {
    "build": "esbuild src/expiration.handler.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --external:@aws-sdk/*",
    "test": "jest --no-coverage",
    "test:coverage": "jest"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/aws-lambda": "^8.10.0",
    "esbuild": "^0.24.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0",
    "aws-sdk-client-mock": "^4.0.0",
    "aws-sdk-client-mock-jest": "^4.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.spec.ts"]
  }
}
