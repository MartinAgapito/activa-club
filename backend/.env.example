# ============================================================
# ActivaClub Backend — Environment Variables Template
# Copy this file to .env and fill in the values for local dev.
# NEVER commit .env to version control.
# In production, values are injected via AWS Lambda env config
# (sourced from AWS SSM Parameter Store via Terraform).
# ============================================================

# Application
NODE_ENV=development
ENV=dev
PORT=3000

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<local-or-dev-key>
AWS_SECRET_ACCESS_KEY=<local-or-dev-secret>

# DynamoDB
DYNAMODB_REGION=us-east-1
# Table names (injected per service, override below for local)
MEMBERS_TABLE_NAME=MembersTable-dev
RESERVATIONS_TABLE_NAME=ReservationsTable-dev
PAYMENTS_TABLE_NAME=PaymentsTable-dev
PROMOTIONS_TABLE_NAME=PromotionsTable-dev
GUESTS_TABLE_NAME=GuestsTable-dev
AREAS_TABLE_NAME=AreasTable-dev

# Cognito
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
# JWKS endpoint is derived automatically from COGNITO_REGION and COGNITO_USER_POOL_ID
# https://cognito-idp.<region>.amazonaws.com/<userPoolId>/.well-known/jwks.json

# Stripe (payments service only)
STRIPE_SECRET_KEY=sk_test_XXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXX

# SNS (promotions service only)
SNS_PROMOTIONS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:ActivaClubPromotions-dev
