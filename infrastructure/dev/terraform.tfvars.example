# ============================================================
# infrastructure/dev/terraform.tfvars.example
#
# Copy this file to terraform.tfvars and fill in the values
# for your DEV account. terraform.tfvars is gitignored.
#
# Usage:
#   cp terraform.tfvars.example terraform.tfvars
#   # Edit terraform.tfvars with your DEV account details
#   terraform init
#   terraform plan
# ============================================================

# AWS account ID of the DEV account.
# Find it with: aws sts get-caller-identity --query Account --output text
dev_account_id = "REPLACE_WITH_DEV_ACCOUNT_ID"

# IAM role to assume in the DEV account.
# Default value matches the convention; change only if your setup differs.
dev_role_name = "activa-club-terraform-dev-role"

# AWS region — keep in sync with the backend "s3" block in main.tf.
aws_region = "us-east-1"

# Environment label — drives resource name suffixes (e.g. MembersTable-dev).
env = "dev"

# Project tag applied to every resource for cost tracking.
project = "activa-club"
